{
  "name": "steamlib",
  "displayName": "SteamLIB - FitGirl & Dodi 's Extension Steam",
  "version": "1.0.0",
  "description": "Open Steam games on FitGirl, DODI, Xatab, GOG, or more in one click.",
  "author": "NubPlayz",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "plasmo package"
  },
  "dependencies": {
    "animejs": "^4.3.6",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "^0.0.258",
    "@types/node": "20.11.5",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://store.steampowered.com/app/*",
      "https://store.steampowered.com/agecheck/app/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "steamlib@NubPlayz.com",
        "data_collection_permissions": {
          "required": [
            "none"
          ],
          "optional": []
        }
      }
    }
  }
}
